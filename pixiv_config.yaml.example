# Pixiv 配置文件

# Pixiv refresh token（必需）
# 获取方法：登录 Pixiv 后，在浏览器开发者工具中查看网络请求
refresh_token: "your_refresh_token_here"

# 代理设置（可选）
# 如果需要使用代理访问 Pixiv，请设置代理地址
# 例如: "http://127.0.0.1:10809" 或 "socks5://127.0.0.1:1080"
proxy: null

# Mock 模式（开发用）
# true: 本地开发，维护任务默认每次只拉取 10 份作品
# false: 生产环境
mock_mode: true

# 数据库路径（可选，默认为 dataset.db）
db_path: "dataset.db"

# 自动维护参数
counts_config:
  # 待评分图片数量低于此值时，维护任务会进入“补图批次”
  min_wait: 20

  # 生产模式每次补图批次拉取的作品数量
  fetch_count: 50

  # 补图批次里单次最多处理多少个收藏/取消收藏任务
  bookmark_batch_size: 10

  # 应用退出前冲刷收藏任务队列时的批大小
  bookmark_shutdown_batch_size: 50
