# Pixiv 配置文件

# Pixiv refresh token（必需）
# 获取方法：登录 Pixiv 后，在浏览器开发者工具中查看网络请求
refresh_token: "your_refresh_token_here"

# 代理设置（可选）
# 如果需要使用代理访问 Pixiv，请设置代理地址
# 例如: "http://127.0.0.1:10809" 或 "socks5://127.0.0.1:1080"
proxy: null

# Mock 模式（开发用）
# true: 使用本地目录模拟 R2，适合 Windows 本地开发
# false: 使用真实的 R2 挂载目录
mock_mode: true

# 图片存储目录
# mock_mode=true 时使用本地目录
# mock_mode=false 时使用 R2 挂载目录
storage_path:
  mock: "./mock_r2/pixiv_dataset"
  production: "~/cf_r2/cf-disk/pixiv_dataset"

# 数据库路径（可选，默认为 dataset.db）
db_path: "dataset.db"

# Cloudflare R2 配置
r2:
  # R2 bucket 的公开访问 URL
  # 例如: "https://your-bucket.r2.dev"
  base_url: "https://your-bucket.r2.dev"

  # 图片在 R2 中的路径前缀
  # 例如: "pixiv_dataset" 对应 R2 中的 /pixiv_dataset/ 路径
  path_prefix: "pixiv_dataset"

  # Mock 模式下的本地 URL 前缀
  # 用于在本地开发时访问图片
  mock_base_url: "http://localhost:8000/static/mock_r2"
